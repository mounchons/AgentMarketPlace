    "assignment_strategy": {
      "_comment": "Risk-based model assignment v1.6. Evaluates rules top-down; first match wins. 3-tier model: opus (complex flow), sonnet (standard CRUD), haiku (P3 trivial CRUD). Each scenario gets risk{score,priority,factors[]} computed from probability(1-3) x impact(1-3). complexity_factors[] track flow difficulty (state-machine, cascade-deep, multi-step, concurrent, security-flow, network-mock, master-detail-sync, cross-browser).",
      "auto_assign_rules": [
        { "condition": "complexity_factors.length >= 2", "assign": "opus", "reason": "multiple complexity factors require deep reasoning" },
        { "condition": "complexity_factors.includes('state-machine')", "assign": "opus", "reason": "state transitions need flow-aware reasoning" },
        { "condition": "complexity_factors.includes('cascade-deep')", "assign": "opus", "reason": "cascade depth >= 2 requires cross-module reasoning" },
        { "condition": "complexity_factors.includes('concurrent')", "assign": "opus", "reason": "race conditions need careful sequencing" },
        { "condition": "complexity_factors.includes('cross-browser')", "assign": "opus", "reason": "cross-browser diff analysis is non-trivial" },
        { "condition": "complexity_factors.includes('security-flow') && risk.priority == 'P0'", "assign": "opus", "reason": "P0 security flows need exhaustive coverage" },
        { "condition": "complexity_factors.includes('master-detail-sync')", "assign": "opus", "reason": "master-detail sync requires verifying multiple states" },
        { "condition": "complexity_factors.includes('network-mock') && risk.priority == 'P0'", "assign": "opus", "reason": "P0 with mock sequences need precise scripting" },
        { "condition": "complexity_factors.includes('multi-step') && risk.priority in ['P0','P1']", "assign": "opus", "reason": "multi-step P0/P1 wizards need branch reasoning" },
        { "condition": "risk.priority == 'P0' && complexity_factors.length >= 1", "assign": "opus", "reason": "P0 with any factor warrants opus" },
        { "condition": "risk.priority == 'P3' && complexity_factors.length == 0", "assign": "haiku", "reason": "P3 trivial CRUD — pattern-based, no reasoning required" },
        { "condition": "default", "assign": "sonnet", "reason": "standard CRUD / mid-complexity flow" }
      ]
    }
  },
